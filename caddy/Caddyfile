{
    auto_https off
}

:80 {

    log {
        output stdout
        format json
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
    }

    respond /health 200 {
        body "healthy"
    }

    # API → Backend
    handle /api/* {
        reverse_proxy backend:3000
    }

    # Production UI
    handle /production {
        rewrite * /production.html
        reverse_proxy frontend:80
    }

    # React SPA
    handle {
        reverse_proxy frontend:80
    }
}
