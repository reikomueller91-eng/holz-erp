{
  "name": "holz-erp-backend",
  "version": "0.1.0",
  "description": "HolzERP – Sawn wood production management system backend",
  "author": "HolzERP",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch --inspect=0.0.0.0:9229 src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:migrate:rollback": "tsx src/infrastructure/db/migrate.ts rollback",
    "db:seed": "tsx src/infrastructure/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/static": "^7.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^3.0.0",
    "argon2": "^0.31.2",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.2",
    "imap": "^0.8.19",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pino": "^8.19.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/imapflow": "^1.0.23",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.56.0",
    "supertest": "^6.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
