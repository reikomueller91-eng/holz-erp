# HolzERP – Environment Configuration
# Copy to .env and adjust values. NEVER commit .env to git!

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────────
DB_PATH=/data/holz.db

# ─── File Storage ───────────────────────────────────────────────
FILE_STORE_PATH=/data/files

# ─── Security ───────────────────────────────────────────────────
# JWT signing (separate from MasterKey — do not reuse!)
JWT_SECRET=CHANGE_ME_USE_RANDOM_64_CHAR_STRING

# ─── Kleinanzeigen (optional) ───────────────────────────────────
# KLEINANZEIGEN_API_KEY=
# KLEINANZEIGEN_USER_ID=

# ─── PDF Generation ─────────────────────────────────────────────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ─── CORS (dev only) ────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:5173
