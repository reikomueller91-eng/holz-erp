# HolzERP – Environment Configuration
# Copy to .env and adjust values. NEVER commit .env to git!

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────────
DB_PATH=/data/holz.db

# ─── File Storage ───────────────────────────────────────────────
FILE_STORE_PATH=/data/files

# ─── Security ───────────────────────────────────────────────────
# JWT signing (separate from MasterKey — do not reuse!)
JWT_SECRET=CHANGE_ME_USE_RANDOM_64_CHAR_STRING

# ─── Email (IMAP for incoming, SMTP for outgoing) ──────────────
# IMAP - E-Mails abrufen
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=reikomueller91@gmail.com
IMAP_PASSWORD=YOUR_APP_PASSWORD
IMAP_TLS=true

# SMTP - E-Mails versenden
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=reikomueller91@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD

# E-Mail Filter - Betreff-Zeilen die verarbeitet werden sollen
EMAIL_FILTER_KEYWORDS=angebot,anfrage,holz,produkt,preis,kaufen,bestellen

# ─── Kleinanzeigen (optional) ───────────────────────────────────
# KLEINANZEIGEN_API_KEY=
# KLEINANZEIGEN_USER_ID=

# ─── PDF Generation ─────────────────────────────────────────────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ─── CORS (dev only) ────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:5173